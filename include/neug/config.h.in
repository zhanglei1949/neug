#pragma once

#include <cstdint>
#include <string>

/**
 * @file config.h
 * @brief Build-time configuration macros for NeuG
 */

namespace neug {

/**
 * @brief Database access mode enumeration.
 *
 * Specifies whether the database is opened for read-only or read-write access.
 *
 * @since v0.1.0
 */
enum class DBMode {
  READ_ONLY = 0,  ///< Read-only access for analytics workloads
  READ_WRITE = 1  ///< Full transactional read-write access
};

/**
 * @brief Memory usage level enumeration.
 *
 * Defines the memory usage strategy for NeugDB, allowing users to choose
 * between different levels of memory optimization and performance.
 *
 * @since v0.1.0
 */
enum class MemoryLevel : uint8_t {
  kUnSet = 0,
  kInMemory = 1,
  kSyncToFile = 2,
  kHugePagePreferred = 3
};

/**
 * @brief Configuration structure for NeugDB initialization.
 *
 * NeugDBConfig provides comprehensive configuration options for
 * database initialization, including storage settings, threading,
 * and persistence behavior.
 *
 * **Usage Example:**
 * @code{.cpp}
 * neug::NeugDBConfig config;
 * config.data_dir = "/path/to/graph";
 * config.thread_num = 8;
 * config.mode = neug::DBMode::READ_WRITE;
 * config.memory_level = 1;  // Use memory-mapped virtual memory
 * config.enable_auto_compaction = true;
 * config.checkpoint_on_close = true;
 *
 * neug::NeugDB db;
 * db.Open(config);
 * @endcode
 *
 * **Memory Levels:**
 * - 0: Unset
 * - 1: Memory-mapped virtual memory (default, balanced)
 * - 2: Sync with disk (lowest memory, highest I/O latency)
 * - 3: Prefer hugepages (better TLB performance)
 *
 * @see NeugDB::Open For using this configuration
 *
 * @since v0.1.0
 */
struct NeugDBConfig {
  /// Default CSR reserve ratio for edge storage
  static constexpr const float DEFAULT_RESERVE_RATIO = 1.2;

  /**
   * @brief Default constructor with sensible defaults.
   */
  NeugDBConfig()
      : csr_reserve_ratio(DEFAULT_RESERVE_RATIO),
        mode(DBMode::READ_WRITE),
        planner_kind("gopt"),
        thread_num(1),
        enable_auto_compaction(false),
        memory_level(MemoryLevel::kInMemory),
        compact_csr(true),
        compact_on_close(false),
        checkpoint_on_close(false),
        checkpoint_after_recovery(false) {}

  /**
   * @brief Construct with data directory and thread count.
   *
   * @param data_dir_ Path to graph data directory
   * @param thread_num_ Number of threads for concurrent operations
   */
  NeugDBConfig(const std::string& data_dir_, int thread_num_ = 1)
      : csr_reserve_ratio(DEFAULT_RESERVE_RATIO),
        mode(DBMode::READ_WRITE),
        data_dir(data_dir_),
        planner_kind("gopt"),
        thread_num(thread_num_),
        enable_auto_compaction(false),
        memory_level(MemoryLevel::kInMemory),
        compact_csr(true),
        compact_on_close(false),
        checkpoint_on_close(false),
        checkpoint_after_recovery(false) {}

  /// CSR storage reserve ratio for edge insertions (default: 1.2)
  float csr_reserve_ratio;

  /// Database access mode (READ_ONLY or READ_WRITE)
  DBMode mode;

  /// Path to graph data directory
  std::string data_dir;

  /// Query planner type: "gopt" (Graph Optimizer) or "greedy"
  std::string planner_kind;

  /// Number of threads for concurrent operations
  int thread_num;

  /// Enable background auto-compaction thread
  bool enable_auto_compaction;

  /**
   * @brief Memory usage level.
   *
   * - 0: Sync with disk
   * - 1: Memory-mapped virtual memory (default)
   * - 2: Prefer hugepages
   */
  MemoryLevel memory_level;

  /// Compact CSR structures during compaction
  bool compact_csr;

  /// Perform compaction when closing database
  bool compact_on_close;

  /// Create checkpoint (persist all data) when closing database
  bool checkpoint_on_close;

  /// Create checkpoint after recovering from WAL
  bool checkpoint_after_recovery;
};

}  // namespace neug
